{
  "compilerOptions": {
    "module": "Node16",
    "target": "es2020",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@/*": ["./src/*"]
    },
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "types": ["node", "jest"]
}